# ── Database ──────────────────────────────────────────────────────────────────
# In Docker these are set by docker-compose. Leave blank to fall back to PGlite.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cio_dashboard
DB_USER=cio_user
DB_PASSWORD=

# ── JWT Secrets (REQUIRED — use strong random strings, min 32 chars) ──────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://YOUR_SERVER_IP

# ── OpManager Integration (leave blank to disable) ───────────────────────────
OPMANAGER_HOST=
OPMANAGER_API_KEY=
OPMANAGER_WIDGETS=

# ── Wazuh Integration (leave blank to disable) ───────────────────────────────
WAZUH_HOST=
WAZUH_USER=
WAZUH_PASSWORD=
WAZUH_DASHBOARD_URL=

# ── SOC Email (leave blank to disable) ───────────────────────────────────────
SOC_EMAIL_HOST=
SOC_EMAIL_USER=
SOC_EMAIL_PASSWORD=
SOC_EMAIL_PORT=993
